# Copy to .env and fill in values before running docker-compose
# Never commit .env to version control

# ── Database (Supabase PostgreSQL) ────────────────────────────
# Format: jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# Or via Supabase connection pooler (recommended for serverless / small pools):
# jdbc:postgresql://aws-0-<region>.pooler.supabase.com:6543/postgres?user=postgres.<project-ref>&password=<password>&sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_database_password

# ── Supabase Storage ──────────────────────────────────────────
# Project URL — found in Supabase dashboard → Settings → API → Project URL
SUPABASE_URL=https://<project-ref>.supabase.co
# Service Role key — Settings → API → service_role (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Name of the Storage bucket (must exist and be set to public in Supabase dashboard)
SUPABASE_BUCKET=bulletbeats

# ── Application ───────────────────────────────────────────────
APP_BASE_URL=http://your-server-ip-or-domain:8080

# ── Logging (DEBUG / INFO / WARN) ────────────────────────────
LOG_LEVEL=INFO
